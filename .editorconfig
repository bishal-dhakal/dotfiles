# EditorConfig: https://editorconfig.org
# Ensures consistent coding styles across different editors and IDEs

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{lua,json,yaml,yml,toml}]
indent_style = space
indent_size = 2

[*.{py,pyw}]
indent_style = space
indent_size = 4
max_line_length = 88

[*.{java}]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{c,cpp,h,hpp,cc}]
indent_style = space
indent_size = 4

[*.rs]
indent_style = space
indent_size = 4
max_line_length = 100

[*.go]
indent_style = tab
indent_size = 4

[*.{js,jsx,ts,tsx,html,css,scss,jsonc}]
indent_style = space
indent_size = 2

[*.{sh,bash,zsh}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

